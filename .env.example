NODE_ENV=development
LOG_LEVEL=info
SHELBY_PROVIDER=mock
SHELBY_NETWORK=local
SHELBY_ACCOUNT_ID=demo-account
SHELBY_API_URL=
SHELBY_API_KEY=
SHELBY_PRIVATE_KEY=
SHELBY_WORKDIR=.shelby-workdir
SHELBY_STORAGE_DIR=.shelby-system/storage
TEMP_DIR=.shelby-system/tmp
MAX_UPLOAD_SIZE_MB=50
MAX_READ_TEXT_BYTES=65536
STREAM_UPLOAD_CHUNK_SIZE_BYTES=262144
SHELBY_STRICT_METADATA=false
SHELBY_REQUIRED_METADATA_KEYS=
SHELBY_DEFAULT_CONTENT_OWNER=
SHELBY_DEFAULT_CLASSIFICATION=
SHELBY_DEFAULT_SOURCE=
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=
TELEMETRY_ENVIRONMENT=development
TELEMETRY_SAMPLE_RATE=1
ALLOW_DESTRUCTIVE_TOOLS=false
